{
  "name": "totp-desktop",
  "version": "1.0.0",
  "description": "OTP.2FA 验证码桌面工具 - 跨平台",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "dev:all": "concurrently -k \"vite\" \"sleep 1.5 && NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production electron .",
    "icons": "node scripts/generate-icons.js",
    "pack": "npm run icons && vite build && electron-builder --dir",
    "dist": "npm run icons && vite build && electron-builder"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.otp2fa.desktop",
    "productName": "OTP.2FA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
